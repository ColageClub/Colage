// Secrets.xcconfig.example — copy to Secrets.xcconfig and fill in your keys
// Note: :// in URLs is treated as a comment in xcconfig, so we use SCHEME_SEP workaround

MAPBOX_ACCESS_TOKEN = your-mapbox-public-token-here
SCHEME_SEP = ://
API_BASE_URL = https$(SCHEME_SEP)wn7mxcdxca.execute-api.us-east-2.amazonaws.com/dev
WS_BASE_URL = wss$(SCHEME_SEP)w0m7jw00ak.execute-api.us-east-2.amazonaws.com/dev
AD_BASE_URL = https$(SCHEME_SEP)main.dcinq8hq6li09.amplifyapp.com
